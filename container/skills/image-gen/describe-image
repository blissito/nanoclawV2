#!/usr/bin/env bash
# describe-image: describe whats in an image using OpenAI gpt-4o-mini vision
# Usage:
#   describe-image /path/to/image.jpg
#   describe-image /path/to/image.jpg "is there a cat?"
set -euo pipefail

IMAGE_PATH="${1:?Usage: describe-image /path/to/image [question]}"
QUESTION="${2:-Describe what is in this image in detail. If there is text, include it verbatim.}"

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "ERROR: OPENAI_API_KEY not set" >&2
  exit 1
fi

if [[ ! -f "$IMAGE_PATH" ]]; then
  echo "ERROR: image not found: $IMAGE_PATH" >&2
  exit 1
fi

IMAGE_URI=$(python3 -c "
import base64, sys, mimetypes
path = sys.argv[1]
mime = mimetypes.guess_type(path)[0] or \"image/jpeg\"
with open(path, \"rb\") as f:
    print(f\"data:{mime};base64,\" + base64.b64encode(f.read()).decode())
" "$IMAGE_PATH")

PAYLOAD=$(IMAGE_URI="$IMAGE_URI" Q="$QUESTION" python3 -c "
import json, os
print(json.dumps({
  \"model\": \"gpt-4o-mini\",
  \"messages\": [{
    \"role\": \"user\",
    \"content\": [
      {\"type\": \"text\", \"text\": os.environ[\"Q\"]},
      {\"type\": \"image_url\", \"image_url\": {\"url\": os.environ[\"IMAGE_URI\"]}}
    ]
  }],
  \"max_tokens\": 800
}))")

RESPONSE=$(printf %s "$PAYLOAD" | curl -sS -X POST https://api.openai.com/v1/chat/completions   -H "Authorization: Bearer $OPENAI_API_KEY"   -H "Content-Type: application/json"   -d @-)

ERROR=$(python3 -c "
import json, sys
d = json.load(sys.stdin)
e = d.get(\"error\", {})
if isinstance(e, dict) and e.get(\"message\"):
    print(e[\"message\"])
" <<< "$RESPONSE" 2>/dev/null || true)

if [[ -n "$ERROR" ]]; then
  echo "ERROR: OpenAI API: $ERROR" >&2
  exit 1
fi

python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d[\"choices\"][0][\"message\"][\"content\"])
" <<< "$RESPONSE"
