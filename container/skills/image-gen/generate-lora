#!/usr/bin/env bash
# generate-lora: generate images using a trained FLUX LoRA
# Usage:
#   generate-lora "trigger_word" "prompt with trigger_word in a scene"
#   generate-lora "ghosty_plush" "ghosty_plush wearing a santa hat in snow"
#
# Reads LoRA config from /workspace/agent/lora-<trigger>.json (created by train-lora).
# Cost: ~$0.02/image.
set -euo pipefail

TRIGGER="${1:?Usage: generate-lora \"trigger_word\" \"prompt\"}"
PROMPT="${2:?Usage: generate-lora \"trigger_word\" \"prompt with trigger_word\"}"

if [[ -z "${FAL_KEY:-}" ]]; then
  echo "ERROR: FAL_KEY not set" >&2
  exit 1
fi

OUTPUT_DIR="/workspace/agent"
LORA_FILE="${OUTPUT_DIR}/lora-${TRIGGER}.json"
OUTPUT_FILE="${OUTPUT_DIR}/lora-$(date +%s%3N).jpg"

if [[ ! -f "$LORA_FILE" ]]; then
  echo "ERROR: No LoRA config at $LORA_FILE — run train-lora first" >&2
  exit 1
fi

# Read LoRA URL from config
LORA_URL=$(python3 -c "
import json, sys
print(json.load(open(sys.argv[1]))['lora_url'])
" "$LORA_FILE")

# Build payload
PAYLOAD=$(LORA_PROMPT="$PROMPT" LORA_URL_VAL="$LORA_URL" python3 -c "
import json, os
print(json.dumps({
    'prompt': os.environ['LORA_PROMPT'],
    'loras': [{'path': os.environ['LORA_URL_VAL'], 'scale': 1.0}],
    'output_format': 'jpeg',
    'num_images': 1,
    'image_size': 'square_hd',
    'num_inference_steps': 28,
    'guidance_scale': 3.5
}))
")

# Submit to fal.ai queue
RESPONSE=$(printf '%s' "$PAYLOAD" | curl -sS -X POST "https://queue.fal.run/fal-ai/flux-lora" \
  -H "Authorization: Key $FAL_KEY" \
  -H "Content-Type: application/json" \
  -d @-)

# Check for immediate error
ERROR=$(python3 -c "
import json, sys
d = json.load(sys.stdin)
if 'detail' in d:
    print(d['detail'] if isinstance(d['detail'], str) else json.dumps(d['detail']))
elif 'error' in d:
    print(d['error'])
" <<< "$RESPONSE" 2>/dev/null || true)

if [[ -n "$ERROR" ]]; then
  echo "ERROR: fal.ai: $ERROR" >&2
  exit 1
fi

# Poll queue for result
REQUEST_ID=$(python3 -c "
import json, sys
print(json.load(sys.stdin).get('request_id', ''))
" <<< "$RESPONSE")

if [[ -n "$REQUEST_ID" ]]; then
  for i in $(seq 1 90); do
    sleep 2
    STATUS_RESPONSE=$(curl -sS "https://queue.fal.run/fal-ai/flux-lora/requests/$REQUEST_ID/status" \
      -H "Authorization: Key $FAL_KEY")
    STATUS=$(python3 -c "
import json, sys
print(json.load(sys.stdin).get('status', ''))
" <<< "$STATUS_RESPONSE")
    if [[ "$STATUS" == "COMPLETED" ]]; then
      RESPONSE=$(curl -sS "https://queue.fal.run/fal-ai/flux-lora/requests/$REQUEST_ID" \
        -H "Authorization: Key $FAL_KEY")
      break
    elif [[ "$STATUS" == "FAILED" ]]; then
      echo "ERROR: fal.ai LoRA generation failed" >&2
      exit 1
    fi
  done
fi

# Download result image
IMAGE_URL=$(python3 -c "
import json, sys
d = json.load(sys.stdin)
images = d.get('images', [])
print(images[0]['url'] if images else '')
" <<< "$RESPONSE")

if [[ -z "$IMAGE_URL" ]]; then
  echo "ERROR: No image URL in response" >&2
  echo "Response: $RESPONSE" >&2
  exit 1
fi

curl -sS -o "$OUTPUT_FILE" "$IMAGE_URL"


echo "$OUTPUT_FILE"
